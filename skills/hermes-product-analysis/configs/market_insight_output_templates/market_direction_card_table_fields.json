{
  "table_name": "市场方向卡表",
  "description": "一行一个 MarketDirectionCard，供阶段 2 选品流程直接读取。",
  "fields": [
    {"field_name": "方向规范Key", "field_type": "text", "required": true},
    {"field_name": "方向实例ID", "field_type": "text", "required": true},
    {"field_name": "批次日期", "field_type": "date", "required": true},
    {"field_name": "国家", "field_type": "single_select", "required": true},
    {"field_name": "类目", "field_type": "single_select", "required": true},
    {"field_name": "方向名称", "field_type": "text", "required": true},
    {"field_name": "主风格", "field_type": "single_select", "required": true},
    {"field_name": "方向大类", "field_type": "single_select", "required": false},
    {"field_name": "方向层级", "field_type": "single_select", "required": false},
    {"field_name": "产品形态/结果", "field_type": "single_select", "required": false},
    {"field_name": "主要承载形态", "field_type": "multi_select", "required": false},
    {"field_name": "形态分布", "field_type": "long_text", "required": false},
    {"field_name": "形态分布_商品数", "field_type": "long_text", "required": false},
    {"field_name": "形态分布_销量", "field_type": "long_text", "required": false},
    {"field_name": "核心价值点", "field_type": "multi_select", "required": false},
    {"field_name": "核心元素", "field_type": "multi_select", "required": true},
    {"field_name": "核心场景", "field_type": "multi_select", "required": false},
    {"field_name": "目标价格带", "field_type": "multi_select", "required": false},
    {"field_name": "热度等级", "field_type": "single_select", "required": true},
    {"field_name": "拥挤度等级", "field_type": "single_select", "required": true},
    {"field_name": "方向商品数", "field_type": "number", "required": false},
    {"field_name": "方向7日销量中位数", "field_type": "number", "required": false},
    {"field_name": "平均视频密度", "field_type": "number", "required": false},
    {"field_name": "平均达人密度", "field_type": "number", "required": false},
    {"field_name": "默认内容路线偏好", "field_type": "single_select", "required": false},
    {"field_name": "任务类型", "field_type": "text", "required": false},
    {"field_name": "目标任务池", "field_type": "text", "required": false},
    {"field_name": "任务Brief来源", "field_type": "text", "required": false},
    {"field_name": "任务Brief置信度", "field_type": "text", "required": false},
    {"field_name": "选品任务要求", "field_type": "long_text", "required": false},
    {"field_name": "代表商品ID", "field_type": "long_text", "required": false},
    {"field_name": "代表商品名称", "field_type": "long_text", "required": false},
    {"field_name": "选品建议", "field_type": "long_text", "required": true},
    {"field_name": "避坑提示", "field_type": "long_text", "required": true},
    {"field_name": "是否最新批次", "field_type": "checkbox", "required": false}
  ]
}
