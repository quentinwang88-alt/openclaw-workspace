# =========================
# 机器角色
# main = 主电脑正式运行机
# dev  = 第二台开发机
# =========================
THIS_MACHINE_ROLE=dev

# =========================
# OpenClaw 路径
# 一般不需要改；bootstrap 会自动创建这些目录
# =========================
OPENCLAW_HOME=~/.openclaw
OPENCLAW_WORKSPACE_ROOT=~/.openclaw/workspace
OPENCLAW_SHARED_DATA_DIR=~/.openclaw/shared/data
OPENCLAW_MEDIA_INBOUND_DIR=~/.openclaw/media/inbound

# =========================
# Creator CRM / 通用飞书配置
# 用于 creator-crm、video-remake-lite 等主流程
# =========================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=

# =========================
# Creator CRM LLM 配置
# =========================
LLM_API_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_API_KEY=
LLM_MODEL=Doubao-Seed-2.0-pro

CATEGORY_API_URL=https://ark.cn-beijing.volces.com/api/v3
CATEGORY_API_KEY=
CATEGORY_MODEL=doubao-seed-2-0-mini-260215

CLAUDE_API_BASE_URL=https://www.ai678.top/v1
CLAUDE_API_KEY=
GEMINI_API_BASE_URL=https://yunwu.ai/v1
GEMINI_API_KEY=

# =========================
# Creator CRM 批处理参数
# =========================
CREATOR_BATCH_SIZE=20
CREATOR_BATCH_INTERVAL=300

# =========================
# Creator Monitoring Assistant
# 如果只看代码，可先留空
# 如果要跑本地验证，建议先填下面几项
# =========================
DATABASE_URL=sqlite:////Users/your-name/.openclaw/shared/data/creator_monitoring.sqlite3
CREATOR_MONITORING_PROJECT_ROOT=
CREATOR_MONITORING_FEISHU_APP_TOKEN=
CREATOR_MONITORING_FEISHU_TABLE_ID=
FEISHU_ENABLE_SYNC=false
FEISHU_WRITE_BATCH_SIZE=100
FEISHU_READ_PAGE_SIZE=200
PLATFORM_DEFAULT=tiktok
COUNTRY_DEFAULT=th
STORE_DEFAULT=
RULE_VERSION=v1

# =========================
# Creator Monitoring 规则参数
# =========================
TOP_PERCENT_CORE=0.2
VOLATILITY_DROP_RATIO=0.6
REFUND_RISK_MULTIPLIER=1.5
STOP_LOSS_LOW_EFFICIENCY_RATIO=0.5
ROLLING_WINDOW_WEEKS=4
NEW_CREATOR_MAX_WEEKS=4
MIN_WEEKS_FOR_VOLATILITY=3
MIN_VALID_GMV=100
MIN_VALID_ORDER_COUNT=3
MIN_VALID_CONTENT_ACTION_COUNT=1
MIN_VALID_SAMPLE_COUNT=1
MIN_POSITIVE_EFFICIENCY_PEER_COUNT=5

# =========================
# 其他可选接口
# =========================
APIFY_API_TOKEN=
KALODATA_API_KEY=
ANTHROPIC_API_KEY=

PRODUCT_CANDIDATE_ENRICHER_TIMEZONE=Asia/Shanghai
PRODUCT_CANDIDATE_ENRICHER_LLM_BASE_URL=https://yunwu.ai/v1
PRODUCT_CANDIDATE_ENRICHER_LLM_API_KEY=
PRODUCT_CANDIDATE_ENRICHER_LLM_MODEL=gpt-4.1-nano
